<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="EMI Calculator Automation Suite" verbose="1">

    <parameter name="browser" value="chrome"/>

    <test name="Car Loan Tests">
        <classes>
            <class name="tests.CarLoanTest"/>
        </classes>
    </test>

    <test name="Home Loan Tests">
        <classes>
            <class name="tests.HomeLoanTest"/>
        </classes>
    </test>

    <test name="Loan Calculator UI Tests">
        <classes>
            <class name="tests.LoanCalculatorUITest"/>
        </classes>
    </test>

</suite>